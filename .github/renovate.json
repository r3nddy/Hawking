{
  "extends": [
    "config:recommended",
    ":timezone(Asia/Jakarta)"
  ],
  "postUpdateOptions": ["gomodTidy"],
  "dependencyDashboard": false,
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Go dependencies (non-major)"
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "groupName": "Go dependencies (major)"
    }
  ]
}
